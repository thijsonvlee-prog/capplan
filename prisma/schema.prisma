generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// === User Domain (multi-user preparation) ===

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("PLANNER") // ADMIN, PLANNER, VIEWER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  preferences UserPreference[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserPreference {
  id        String   @id @default(uuid())
  userId    String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

// === Master Data ===

model Skill {
  id           String    @id @default(uuid())
  name         String
  sourceSystem String?
  externalId   String?
  syncedAt     DateTime?

  drivers DriverSkill[]
}

model Employer {
  id           String    @id @default(uuid())
  code         String    @unique
  description  String
  sourceSystem String?
  externalId   String?
  syncedAt     DateTime?

  employmentRecords DriverEmploymentRecord[]
}

model Department {
  id           String    @id @default(uuid())
  code         String    @unique
  description  String
  sourceSystem String?
  externalId   String?
  syncedAt     DateTime?

  functionRecords DriverFunctionRecord[]
}

model Location {
  id           String    @id @default(uuid())
  code         String    @unique
  description  String
  sourceSystem String?
  externalId   String?
  syncedAt     DateTime?

  functionRecords DriverFunctionRecord[]
}

model LeaveType {
  id           String    @id @default(uuid())
  code         String    @unique
  description  String
  sourceSystem String?
  externalId   String?
  syncedAt     DateTime?

  planningEntries PlanningEntry[]
}

// === Driver Domain ===

model Driver {
  id             String   @id @default(uuid())
  firstName      String
  lastName       String
  employeeNumber String?
  licenseTypes   String[] // PostgreSQL array
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // AFAS integration preparation
  sourceSystem String?
  externalId   String?
  syncedAt     DateTime?

  // Relations
  skills            DriverSkill[]
  employmentRecords DriverEmploymentRecord[]
  functionRecords   DriverFunctionRecord[]
  rosterAssignments DriverRosterAssignment[]
  planningEntries   PlanningEntry[]

  @@index([lastName, firstName])
  @@index([isActive])
}

model DriverSkill {
  id       String @id @default(uuid())
  driverId String
  skillId  String

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  skill  Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([driverId, skillId])
  @@index([driverId])
  @@index([skillId])
}

model DriverEmploymentRecord {
  id             String  @id @default(uuid())
  driverId       String
  sequenceNumber Int
  startDate      String // YYYY-MM-DD
  endDate        String? // YYYY-MM-DD
  employmentType String // FULLTIME, PARTTIME, ONCALL, TEMPORARY, CHARTER
  employerId     String?

  driver   Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  employer Employer? @relation(fields: [employerId], references: [id], onDelete: SetNull)

  @@index([driverId])
}

model DriverFunctionRecord {
  id             String  @id @default(uuid())
  driverId       String
  sequenceNumber Int
  startDate      String // YYYY-MM-DD
  endDate        String? // YYYY-MM-DD
  position       String
  locationId     String?
  departmentId   String?
  manager        String?

  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  location   Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([driverId])
}

model DriverRosterAssignment {
  id              String  @id @default(uuid())
  driverId        String
  sequenceNumber  Int
  startDate       String // YYYY-MM-DD
  endDate         String? // YYYY-MM-DD
  rosterProfileId String
  weeklyHours     Float?

  driver        Driver        @relation(fields: [driverId], references: [id], onDelete: Cascade)
  rosterProfile RosterProfile @relation(fields: [rosterProfileId], references: [id])

  @@index([driverId])
  @@index([driverId, startDate, endDate])
}

// === Planning Domain ===

model PlanningEntry {
  id             String  @id @default(uuid())
  driverId       String
  date           String // YYYY-MM-DD
  status         String // ROSTER_FREE, BASE_ROSTER, AVAILABLE_EXTRA, LEAVE, SICK
  leaveTypeId    String?
  sickPercentage Int?
  notes          String?
  scenarioId     String? // NULL = default/base scenario

  driver    Driver     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  leaveType LeaveType? @relation(fields: [leaveTypeId], references: [id], onDelete: SetNull)
  scenario  Scenario?  @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([driverId, date, scenarioId])
  @@index([driverId])
  @@index([date])
  @@index([scenarioId])
  @@index([scenarioId, date])
}

// === Scenario Domain ===

model Scenario {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  planningEntries PlanningEntry[]
}

// === Roster Profile Domain ===

model RosterProfile {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  days              RosterProfileDay[]
  rosterAssignments DriverRosterAssignment[]
}

model RosterProfileDay {
  id              String @id @default(uuid())
  rosterProfileId String
  dayOffset       Int // 0-27 (4 weeks = 28 days)
  status          String // ROSTER_FREE, BASE_ROSTER, AVAILABLE_EXTRA

  rosterProfile RosterProfile @relation(fields: [rosterProfileId], references: [id], onDelete: Cascade)

  @@unique([rosterProfileId, dayOffset])
  @@index([rosterProfileId])
}

// === Connectivity Hub ===

model ImportSource {
  id            String   @id @default(uuid())
  name          String
  type          String   @default("CSV") // CSV (extensible to other types later)
  targetEntity  String   // Which entity to import: "drivers", "employers", "departments", "locations"
  fieldMappings Json     @db.JsonB // { sourceColumn: targetField } mapping
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
}

// === Performance Observability ===

model PerformanceEvent {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now())
  environment String   @default("production")
  source      String   // "api", "frontend", "db", "system"
  eventType   String   // "request", "query", "action", "error"
  name        String   // route/action name, e.g. "GET /api/planning/for-range"
  durationMs  Int?
  status      String?  // "success", "error", "slow"
  requestId   String?
  metadata    Json?    @db.JsonB

  @@index([timestamp])
  @@index([source, name, timestamp])
  @@index([eventType, timestamp])
  @@index([status, timestamp])
}

model PerformanceSummary {
  id         String @id @default(uuid())
  date       String // YYYY-MM-DD
  source     String
  name       String
  count      Int
  avgMs      Float
  p95Ms      Float
  maxMs      Float
  minMs      Float
  errorCount Int    @default(0)
  slowCount  Int    @default(0)
  metadata   Json?  @db.JsonB

  @@unique([date, source, name])
  @@index([date])
}
