datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// === ENUMS ===

enum DriverType {
  INTERNAL
  CHARTER
  TEMPORARY
}

enum PlanningStatus {
  ROSTER_FREE
  BASE_ROSTER
  AVAILABLE_EXTRA
  LEAVE
  SICK
  HIRED
}

enum UserRole {
  PLANNER
  VIEWER
  ADMIN
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
}

// === AUTH MODELS ===

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          UserRole  @default(VIEWER)
  ssoSubject    String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  auditLogs     AuditLog[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// === DOMAIN MODELS ===

model Driver {
  id              String      @id @default(cuid())
  afasEmployeeId  String?     @unique
  employeeNumber  String?
  firstName       String
  lastName        String
  type            DriverType  @default(INTERNAL)
  companyName     String?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  planningEntries PlanningEntry[]
  baseRosters     BaseRoster[]
  realizedHours   RealizedHours[]
}

model BaseRoster {
  id          String    @id @default(cuid())
  driverId    String
  dayOfWeek   Int
  startTime   String?
  endTime     String?
  isWorkDay   Boolean   @default(true)
  validFrom   DateTime
  validUntil  DateTime?
  afasSynced  Boolean   @default(false)

  driver      Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, dayOfWeek, validFrom])
}

model PlanningEntry {
  id           String          @id @default(cuid())
  driverId     String
  date         DateTime        @db.Date
  status       PlanningStatus
  startTime    String?
  endTime      String?
  plannedHours Decimal?        @db.Decimal(4, 2)
  notes        String?
  isOverride   Boolean         @default(false)
  sourceAfas   Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  driver       Driver          @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, date])
  @@index([date])
  @@index([status])
}

model RealizedHours {
  id          String   @id @default(cuid())
  driverId    String
  weekNumber  Int
  year        Int
  monday      Decimal? @db.Decimal(4, 2)
  tuesday     Decimal? @db.Decimal(4, 2)
  wednesday   Decimal? @db.Decimal(4, 2)
  thursday    Decimal? @db.Decimal(4, 2)
  friday      Decimal? @db.Decimal(4, 2)
  saturday    Decimal? @db.Decimal(4, 2)
  sunday      Decimal? @db.Decimal(4, 2)
  totalHours  Decimal? @db.Decimal(5, 2)
  importedAt  DateTime @default(now())
  source      String?

  driver      Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, year, weekNumber])
}

model AfasSyncLog {
  id          String     @id @default(cuid())
  connector   String
  status      SyncStatus
  recordCount Int        @default(0)
  errorMsg    String?
  startedAt   DateTime   @default(now())
  completedAt DateTime?
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entityType  String
  entityId    String
  oldValue    Json?
  newValue    Json?
  timestamp   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([timestamp])
}
